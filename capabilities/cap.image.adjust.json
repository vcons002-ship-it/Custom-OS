{
  "id": "cap.image.adjust",
  "version": "0.1.0",
  "appliesTo": [{ "facet": "image", "min": 0.7, "count": "==1" }],
  "intentTriggers": ["edit", "enhance", "crop", "adjust", "fix"],
  "contract": {
    "inputs": { "item": "sub:item", "ops": "adjust-op[]" },
    "outputs": { "result": "sub:item" },
    "tools": [
      { "name": "crop", "bind": "worker:image-ops" },
      { "name": "adjust_levels", "bind": "worker:image-ops" },
      { "name": "suggest_enhancement", "bind": "reasoning" }
    ],
    "reasoning": "prompt-template:image-enhance"
  },
  "surface": { "form": "halo-panel", "controls": ["crop-frame", "sliders", "accept"], "stage": "preview-overlay" },
  "permissions": ["read:selected-items", "write:substrate"],
  "memoryKeys": ["adjustment-preferences"],
  "reversibility": "undoable"
}
